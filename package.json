{
  "name": "ai-explorer",
  "version": "1.1.0",
  "description": "Bảo tàng AI tương tác chạy hoàn toàn trên trình duyệt (song ngữ VN/EN).",
  "private": true,
  "type": "module",
  "scripts": {
    "serve": "http-server -p 8000 -c-1 .",
    "check-assets": "node tests/check-assets.mjs",
    "test:i18n": "node tests/i18n.mjs",
    "test": "node tests/smoke.mjs",
    "test:focus": "node tests/focus-trap.mjs",
    "test:pwa": "node tests/pwa.mjs",
    "test:a11y": "node tests/a11y.mjs",
    "test:seo": "node tests/seo.mjs",
    "build:seo": "node build-seo.mjs",
    "test:all": "npm run check-assets && npm run test:i18n && npm run test:seo && npm test && npm run test:focus && npm run test:pwa && npm run test:a11y"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "http-server": "14.1.1",
    "playwright": "1.61.1",
    "wait-on": "8.0.4"
  }
}
